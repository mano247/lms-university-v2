# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# JWT signing secret — base64-encoded, at least 512 bits (64 bytes) of random data for HS256/HS512.
# Generate a new one with: openssl rand -base64 64
JWT_SECRET=changeme-generate-a-real-base64-secret-with-openssl-rand--base64-64

# Comma-separated list of origins allowed to call this API (CORS). Defaults to the
# Angular dev server if unset. Add the production frontend URL here when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:4200
